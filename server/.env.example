# Server configuration
PORT=5000

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/linkbio

# Secret used to sign JWT auth tokens — use a long random value in production
JWT_SECRET=change_me_to_a_long_random_secret

# URL of the client app (used for CORS and password-reset links)
CLIENT_URL=http://localhost:5173

# Optional SMTP settings for sending password-reset emails.
# If left unset, the reset link is returned in the API response (dev mode).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=LinkBio <no-reply@example.com>
